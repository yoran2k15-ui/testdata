              "value": "={{ !$json.count_prev ? '📈 Stijgend (Nieuw)' : ($json.count_category_id > $json.count_prev ? '📈 Stijgend' : ($json.count_category_id < $json.count_prev ? '📉 Dalend' : '➖ Gelijk')) }}",
